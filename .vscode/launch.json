{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Grok2API: granian",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "granian",
      "args": [
        "--interface",
        "asgi",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--workers",
        "1",
        "app.main:app"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "TZ": "Asia/Shanghai",
        "LOG_LEVEL": "DEBUG",
        "SERVER_HOST": "0.0.0.0",
        "SERVER_PORT": "8000",
        "SERVER_WORKERS": "1",
        "ACCOUNT_STORAGE": "postgresql",
        "ACCOUNT_POSTGRESQL_URL": "postgresql+asyncpg://postgres:postgres@localhost:5432/grok2api",
        "ACCOUNT_REDIS_URL": "redis://localhost:6379/0",
        "FLARESOLVERR_URL": "http://127.0.0.1:8191/",
        "GROK_PROXY__EGRESS__MODE": "single_proxy",
        "GROK_PROXY__EGRESS__PROXY_URL": "http://127.0.0.1:40080",
        "GROK_PROXY__EGRESS__RESOURCE_PROXY_URL": "http://127.0.0.1:40080",
        "GROK_PROXY__CLEARANCE__MODE": "flaresolverr",
        "GROK_PROXY__CLEARANCE__FLARESOLVERR_URL": "http://127.0.0.1:8191/",
        "GROK_PROXY__CLEARANCE__FLARESOLVERR_PROXY_URL": "http://privoxy:8118"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
